#groq api key for fetching data from sanity
GROQ_API_KEY=gsk_your_actual_key_placeholder
# ── App config ────────────────────────────────────────────────
ENVIRONMENT=development
PORT=8001
WORKERS=1
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# ── Rate limits (requests per minute per platform) ────────────
ZEPTO_RATE_LIMIT=10
BLINKIT_RATE_LIMIT=10

# ── Cache TTL ─────────────────────────────────────────────────
# How long to cache a price comparison result (seconds)
CACHE_TTL_SECONDS=300